# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vfsuser:vfspass@localhost:5432/vfsdb

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redispass@localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=26866e57437b12c1c131e80ed29409d911e4751cb793f75c9f234ece8fd6e4a5
JWT_REFRESH_SECRET=855d9d75748e932de4f82b060e7784cdbd27d2819363b20f3cd5eb3a2763fb17
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex string — generate with: openssl rand -hex 32
PROFILE_ENCRYPTION_KEY=be31431b4b5d58de9274c0e103975801f47159645d9b98a5676c42f7f8c21a2a

# ─── Captcha ──────────────────────────────────────────────────────────────────
TWOCAPTCHA_API_KEY=
# Options: twocaptcha | manual
CAPTCHA_SOLVER=twocaptcha

# ─── Proxy ────────────────────────────────────────────────────────────────────
# Default provider label shown in UI
PROXY_DEFAULT_PROVIDER=brightdata

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VFS Bot <noreply@example.com>"

# ─── Web Push ─────────────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─── Automation ───────────────────────────────────────────────────────────────
# Number of concurrent Playwright booking jobs (each ~200MB RAM)
BOOKING_CONCURRENCY=3
# Default monitor poll interval in milliseconds
MONITOR_DEFAULT_INTERVAL_MS=10000
# Directory for per-profile session cookies
SESSION_DIR=/app/sessions
# Max booking retry attempts per job
BOOKING_MAX_RETRIES=3
