# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vfsuser:vfspass@localhost:5432/vfsdb

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redispass@localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex string — generate with: openssl rand -hex 32
PROFILE_ENCRYPTION_KEY=

# ─── Captcha ──────────────────────────────────────────────────────────────────
TWOCAPTCHA_API_KEY=
# Options: twocaptcha | manual
CAPTCHA_SOLVER=manual

# ─── Proxy ────────────────────────────────────────────────────────────────────
# Default provider label shown in UI
PROXY_DEFAULT_PROVIDER=proxyrack
PROXY_HOST=premium.residential.proxyrack.net
PROXY_PORT=10000
PROXY_USERNAME=
PROXY_PASSWORD=
# Optional: 2-letter ISO country for ProxyRack-style sticky exit (match "Applying from": GB=UK, AO=Angola, IN=India…).
# Leave empty if your provider does not use -country-XX in the username.
PROXY_STICKY_GEO=

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot commands and notifications use the BACKEND (Docker) network — not your browser.
# A VPN extension in Chrome only affects that browser; set TELEGRAM_PROXY here if api.telegram.org is blocked from the container.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# HTTP(S) or socks5:// URL, e.g. http://user:pass@host:port or socks5://user:pass@host:1080
TELEGRAM_PROXY=

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VFS Bot <noreply@example.com>"

# ─── Web Push ─────────────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─── Automation ───────────────────────────────────────────────────────────────
# Number of concurrent Playwright booking jobs (each ~200MB RAM)
BOOKING_CONCURRENCY=3
# Default monitor poll interval in ms (30s recommended vs 10s to reduce VFS 403 / blocks)
MONITOR_DEFAULT_INTERVAL_MS=30000
# Directory for per-profile session cookies
SESSION_DIR=/app/sessions
# Max booking retry attempts per job
BOOKING_MAX_RETRIES=3

# ─── Portugal Regional Settings ──────────────────────────────────────────
# Default VFS Portugal Cooldown (5 minutes = 300000ms)
VFS_COOLDOWN_MS=300000
# Show full names in Telegram alerts (true/false)
TELEGRAM_SHOW_APPLICANT_NAMES=true
